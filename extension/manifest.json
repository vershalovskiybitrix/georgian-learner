{
  "manifest_version": 3,
  "name": "Georgian Learner",
  "version": "1.0.0",
  "description": "Passively learn Georgian alphabet. Randomly replaces Latin/Cyrillic letters with Georgian (Mkhedruli) characters as you read web pages.",
  "author": "Vershalovsky",
  "homepage_url": "https://vershalovsky.com",

  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "src/background/service-worker.js"
  },

  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["src/shared/defaults.js", "src/content.js"],
    "run_at": "document_idle"
  }],

  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },

  "web_accessible_resources": [{
    "resources": ["data/mappings/*.json"],
    "matches": ["<all_urls>"]
  }],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  }
}
